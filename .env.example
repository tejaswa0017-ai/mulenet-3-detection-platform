# MuleNet 3.0 Environment Configuration

# Kafka Configuration
KAFKA_BROKERS=localhost:9092,localhost:9093,localhost:9094
KAFKA_CLIENT_ID=mulenet-edge-node
KAFKA_GROUP_ID=mulenet-consumer-group

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mulenet-password
NEO4J_DATABASE=neo4j

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mulenet
POSTGRES_USER=mulenet
POSTGRES_PASSWORD=mulenet-password

# Privacy Configuration
PRIVACY_BUDGET_EPSILON=1.0
PRIVACY_BUDGET_DELTA=0.00001
BLOOM_FILTER_FALSE_POSITIVE_RATE=0.001

# Model Configuration
TGN_MODEL_VERSION=1.0.0
TGN_MEMORY_SIZE=100
TGN_EMBEDDING_DIM=128

# Risk Scoring Configuration
RISK_THRESHOLD_INFORMATIONAL=0.3
RISK_THRESHOLD_MONITORING=0.6
RISK_THRESHOLD_INVESTIGATION=0.85

# Explainability Configuration
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
EXPLANATION_TIMEOUT_MS=4000
LLM_CACHE_TTL_SECONDS=3600

# Compliance Configuration
DEFAULT_JURISDICTION=EU_GDPR
DATA_RETENTION_DAYS=2555
AUDIT_LOG_RETENTION_DAYS=2555

# Performance Configuration
INGESTION_BATCH_SIZE=1000
GRAPH_QUERY_CACHE_TTL_SECONDS=300
MAX_CONCURRENT_EXPLANATIONS=100

# Security Configuration
JWT_SECRET=your-jwt-secret
API_RATE_LIMIT_PER_MINUTE=1000
KEY_ROTATION_DAYS=90

# Monitoring Configuration
PROMETHEUS_PORT=9090
METRICS_ENABLED=true
TRACING_ENABLED=true
LOG_LEVEL=info
